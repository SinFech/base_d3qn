# Local-only Savio/BRC auth values.
# Do not commit real secrets. Put your live values in .secrets/savio.env instead.

SAVIO_PIN=1234
SAVIO_OTP_URI=otpauth://totp/Issuer:account?secret=BASE32SECRET&issuer=Issuer

# Optional if you do not use SAVIO_OTP_URI:
# SAVIO_OTP_SECRET=BASE32SECRET
# SAVIO_OTP_DIGITS=6
# SAVIO_OTP_PERIOD=30
# SAVIO_OTP_ALGORITHM=SHA1
